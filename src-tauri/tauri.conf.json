{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "workroom",
  "version": "0.1.0",
  "identifier": "com.workroom.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && bash scripts/build-orchestrator.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "workroom",
        "width": 960,
        "height": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/orchestrator.js": "orchestrator.js",
      "resources/node_modules/better-sqlite3": "node_modules/better-sqlite3"
    }
  }
}
